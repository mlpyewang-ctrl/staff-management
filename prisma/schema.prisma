generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  password           String
  role               String   @default("EMPLOYEE")
  idCard             String?
  phone              String?
  salary             Float?
  level              String?
  departmentId       String?
  positionId         String?
  startDate          DateTime?
  seniorityStartDate DateTime?
  seniorityEndDate   DateTime?
  companyId          String?
  company            Company? @relation(fields: [companyId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  overtimeApplications OvertimeApplication[]
  leaveApplications    LeaveApplication[]
  performanceReviews   PerformanceReview[] @relation("Reviewer")
  reviewedPerformance  PerformanceReview[] @relation("Reviewee")
  approvals            Approval[]
  leaveBalance         LeaveBalance?
  salaryRecords        SalaryRecord[]
  overtimeSettlements  OvertimeSettlement[]

  department Department? @relation(fields: [departmentId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])

  @@map("users")
}

model Company {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  address     String?
  contact     String?
  phone       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  departments Department[]

  @@map("companies")
}

model OvertimeApplication {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  hours      Float
  type       String   @default("WORKDAY")
  reason     String
  status     String   @default("DRAFT")
  approverId String?
  approvedAt DateTime?
  remark     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  overtimeSettlements OvertimeSettlement[]

  @@index([userId, status, date])
  @@index([status, createdAt])
  @@map("overtime_applications")
}

model LeaveApplication {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String
  startSession   String?
  endSession     String?
  halfDaySession String?
  startDate      DateTime
  endDate        DateTime
  days           Float
  reason         String
  destination    String?
  status         String   @default("DRAFT")
  approverId     String?
  approvedAt     DateTime?
  remark         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, status, startDate])
  @@index([status, createdAt])
  @@map("leave_applications")
}

model LeaveBalance {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year              Int
  annual            Float    @default(5)
  annualEntitlement Float    @default(5)
  sick              Float    @default(10)
  personal          Float    @default(5)
  compensatory      Float    @default(0)
  usedCompensatory  Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([year])
  @@map("leave_balances")
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  year      Int
  type      String
  createdAt DateTime @default(now())

  @@index([year])
  @@index([date])
  @@map("holidays")
}

model SalaryRecord {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month                String
  baseSalary           Float
  seniorityPay         Float    @default(0)
  otherAdjustment      Float    @default(0)
  adjustmentNote       String?
  workdayOvertimeHours Float    @default(0)
  workdayOvertimePay   Float    @default(0)
  weekendOvertimeHours Float    @default(0)
  weekendOvertimePay   Float    @default(0)
  holidayOvertimeHours Float    @default(0)
  holidayOvertimePay   Float    @default(0)
  totalOvertimePay     Float    @default(0)
  compensatoryHours    Float    @default(0)
  deduction            Float    @default(0)
  netSalary            Float
  status               String   @default("DRAFT")
  paidAt               DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  overtimeSettlements OvertimeSettlement[]

  @@unique([userId, month])
  @@index([month, status])
  @@map("salary_records")
}

model OvertimeSettlement {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  overtimeId     String
  overtime       OvertimeApplication  @relation(fields: [overtimeId], references: [id], onDelete: Cascade)
  salaryRecordId String?
  salaryRecord   SalaryRecord?        @relation(fields: [salaryRecordId], references: [id], onDelete: SetNull)
  hours          Float
  settlementType String
  createdAt      DateTime @default(now())

  @@index([overtimeId, settlementType])
  @@index([salaryRecordId])
  @@index([userId, settlementType, createdAt])
  @@map("overtime_settlements")
}

model PerformanceReview {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("Reviewee", fields: [userId], references: [id], onDelete: Cascade)
  period      String
  quality     Int
  efficiency  Int
  attitude    Int
  skill       Int
  teamwork    Int
  totalScore  Float
  comment     String?
  selfComment String?
  reviewerId  String?
  reviewer    User?    @relation("Reviewer", fields: [reviewerId], references: [id])
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, period])
  @@index([status, period])
  @@map("performance_reviews")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  approvalFlows ApprovalFlow[]

  @@map("departments")
}

model ApprovalFlow {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  types        String
  config       String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId, isActive])
  @@map("approval_flows")
}

model Approval {
  id              String   @id @default(cuid())
  applicationId   String
  applicationType String
  applicantId     String
  approverId      String
  approver        User     @relation(fields: [approverId], references: [id])
  status          String
  remark          String?
  createdAt       DateTime @default(now())

  @@index([applicationType, applicationId, createdAt])
  @@index([approverId, createdAt])
  @@index([applicantId, createdAt])
  @@map("approvals")
}

model Position {
  id        String   @id @default(cuid())
  name      String   @unique
  salary    Float
  level     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("positions")
}
